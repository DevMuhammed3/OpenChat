generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  publicNumericId String?   @unique
  name            String?
  username        String    @unique
  email           String    @unique
  emailVerified  Boolean  @default(false)
  avatar          String?
  password        String?
  role            String    @default("USER")
  bio             String?   @db.Text
  phone           String?   @unique
  status          Boolean   @default(false)
  isActive        Boolean   @default(true)
  isOnline Boolean @default(false)

  // Security
  lastLogin        DateTime?
  loginAttempts    Int       @default(0)
  lockedUntil      DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?

  // OAuth
  googleId   String? @unique
  githubId   String? @unique
  discordId  String? @unique
  facebookId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Friend Requests
  sentRequests     FriendRequest[] @relation("sentRequests")
  receivedRequests FriendRequest[] @relation("receivedRequests")

  // Friends
  friends1 Friend[] @relation("friends1")
  friends2 Friend[] @relation("friends2")

  // Messages
  sentMessages Message[] @relation("UserSentMessages")

  messageReactions MessageReaction[]

  // chat 
  chatParticipants ChatParticipant[]

  createdInvites ChatInvite[]
}

model EmailOTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model FriendRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  createdAt  DateTime @default(now())

  status FriendRequestStatus @default(PENDING)


  sender   User @relation("sentRequests", fields: [senderId], references: [id])
  receiver User @relation("receivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])

}

model Friend {
  id        Int      @id @default(autoincrement())
  user1Id   Int
  user2Id   Int
  createdAt DateTime @default(now())

  user1 User @relation("friends1", fields: [user1Id], references: [id])
  user2 User @relation("friends2", fields: [user2Id], references: [id])

  @@unique([user1Id, user2Id])
}

model Message {
  id        Int      @id @default(autoincrement())
  @@index([chatId, createdAt(sort: Desc)])
  chatId    Int
  senderId  Int
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isEdited Boolean @default(false)
  fileUrl   String?
  fileType  String?

  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  replyToId   Int?
  replyTo     Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[] @relation("MessageReplies")

  reactions MessageReaction[]

  chat Chat @relation(fields: [chatId], references: [id])
  sender User @relation("UserSentMessages", fields: [senderId], references: [id])
}

model MessageReaction {
  id Int @id @default(autoincrement())
  @@index([messageId])

  messageId Int
  userId    Int

  emoji String

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

enum ChatType {
  DM
  ZONE
}

model Chat {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique
  type ChatType @default(DM)
  name      String?
  avatar    String?
  createdBy Int?
  createdAt DateTime @default(now())

  invites ChatInvite[]

  participants ChatParticipant[]
  messages     Message[]
}

enum ZoneRole {
  OWNER
  ADMIN
  MEMBER
}

model ChatParticipant {
  id     Int @id @default(autoincrement())
  chatId Int
  userId Int

  role ZoneRole @default(MEMBER)

  chat Chat @relation(fields: [chatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
}

model ChatInvite {
  id   Int    @id @default(autoincrement())
  @@index([chatId])
  code String @unique

  chatId    Int
  createdBy Int

  maxUses Int?
  uses    Int @default(0)

  expiresAt DateTime?

  createdAt DateTime @default(now())

  chat    Chat @relation(fields: [chatId], references: [id])
  creator User @relation(fields: [createdBy], references: [id])
}
